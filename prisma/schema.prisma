generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspacePlan {
  STARTER
  GROWTH
  ENTERPRISE
}

enum UserRole {
  OWNER
  ADMIN
  ANALYST
  VIEWER
}

enum DatasetStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum IngestionStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum ConnectorType {
  SHOPIFY
  STRIPE
  GA4
  S3
}

enum ConnectorStatus {
  CONNECTED
  DISCONNECTED
  ERROR
}

enum ConnectorSyncStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  DEAD_LETTER
}

enum ConnectorSyncTrigger {
  MANUAL
  SCHEDULED
  RETRY
}

enum SavedViewVisibility {
  PRIVATE
  TEAM
}

enum AlertType {
  THRESHOLD
  ANOMALY
}

enum AlertChannel {
  EMAIL
  SLACK
}

enum AlertEventStatus {
  OPEN
  ACKNOWLEDGED
}

enum ExportFormat {
  CSV
  XLSX
  PDF
}

enum ExportJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum GdprRequestType {
  EXPORT
  DELETE
}

enum GdprRequestStatus {
  REQUESTED
  PROCESSING
  COMPLETED
  REJECTED
}

enum SSOProviderType {
  SAML
  OIDC
}

enum DrillStatus {
  PASSED
  FAILED
}

model Workspace {
  id         String      @id @default(cuid())
  name       String
  plan       WorkspacePlan @default(STARTER)
  settings   Json?
  createdAt  DateTime    @default(now())
  users      User[]
  datasets   Dataset[]
  jobs       IngestionJob[]
  auditLogs  AuditLog[]
  invitations Invitation[]
  connectors  Connector[]
  connectorSyncJobs ConnectorSyncJob[]
  savedViews  SavedView[]
  alertRules  AlertRule[]
  alertEvents AlertEvent[]
  exportJobs  ExportJob[]
  subscriptions Subscription[]
  billingEvents BillingEvent[]
  usageMeters UsageMeter[]
  gdprRequests GdprRequest[]
  dpaAgreements DpaAgreement[]
  retentionPolicies RetentionPolicy[]
  subprocessors Subprocessor[]
  ssoConfigs SsoConfig[]
  backupDrills BackupDrill[]
  runbooks Runbook[]
  sloTargets SloTarget[]
  incidents IncidentPlaybook[]
  demoFixtures DemoFixture[]
}

model User {
  id             String      @id @default(cuid())
  workspaceId    String
  email          String      @unique
  passwordHash   String
  role           UserRole
  mfaEnabled     Boolean     @default(false)
  mfaSecret      String?
  mfaBackupCodes Json?
  lastLogin      DateTime?
  createdAt      DateTime    @default(now())
  workspace      Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sessions       Session[]
  auditLogs      AuditLog[]
  datasets       Dataset[]   @relation("DatasetCreatedBy")
  savedViews     SavedView[] @relation("SavedViewCreatedBy")
  createdAlertRules AlertRule[] @relation("AlertRuleCreatedBy")
  acknowledgedAlertEvents AlertEvent[] @relation("AlertEventAcknowledgedBy")
  exportJobs     ExportJob[] @relation("ExportJobCreatedBy")
  gdprRequests   GdprRequest[]
  dpaAgreements  DpaAgreement[]
  backupDrills   BackupDrill[]
  incidents      IncidentPlaybook[]
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String
  expiresAt        DateTime
  ip               String?
  userAgent        String?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id           String    @id @default(cuid())
  workspaceId  String
  userId       String?
  action       String
  resourceType String
  resourceId   String?
  metadata     Json?
  createdAt    DateTime  @default(now())
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Invitation {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  role        UserRole
  tokenHash   String
  expiresAt   DateTime
  acceptedAt  DateTime?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Dataset {
  id             String         @id @default(cuid())
  workspaceId    String
  name           String
  sourceType     String
  status         DatasetStatus  @default(PENDING)
  rowCount       Int            @default(0)
  columnCount    Int            @default(0)
  schema         Json?
  s3RawKey       String?
  s3ProcessedKey String?
  createdById    String
  createdAt      DateTime       @default(now())
  version        Int            @default(1)
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy      User           @relation("DatasetCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  jobs           IngestionJob[]
  exportJobs     ExportJob[]
}

model IngestionJob {
  id             String          @id @default(cuid())
  datasetId      String
  workspaceId    String
  status         IngestionStatus @default(QUEUED)
  idempotencyKey String
  startedAt      DateTime?
  completedAt    DateTime?
  errorMessage   String?
  retryCount     Int             @default(0)
  metadata       Json?
  dataset        Dataset         @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, idempotencyKey])
}

model Connector {
  id            String          @id @default(cuid())
  workspaceId   String
  type          ConnectorType
  status        ConnectorStatus @default(DISCONNECTED)
  displayName   String
  config        Json?
  lastSyncAt    DateTime?
  rowsSynced    Int             @default(0)
  lastError     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  syncJobs      ConnectorSyncJob[]

  @@unique([workspaceId, type])
}

model ConnectorSyncJob {
  id               String               @id @default(cuid())
  connectorId      String
  workspaceId      String
  trigger          ConnectorSyncTrigger
  status           ConnectorSyncStatus  @default(QUEUED)
  attempts         Int                  @default(0)
  maxAttempts      Int                  @default(3)
  errorMessage     String?
  deadLetterReason String?
  metadata         Json?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  connector        Connector            @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  workspace        Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([connectorId, createdAt])
}

model MagicLinkToken {
  id         String    @id @default(cuid())
  email      String
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
}

model OAuthState {
  id           String    @id @default(cuid())
  provider     String
  state        String    @unique
  codeVerifier String
  redirectUri  String
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())
}

model SavedView {
  id          String              @id @default(cuid())
  workspaceId String
  createdById String
  name        String
  pagePath    String
  visibility  SavedViewVisibility @default(PRIVATE)
  isPinned    Boolean             @default(false)
  shareToken  String              @unique
  filters     Json
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy   User                @relation("SavedViewCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([workspaceId, pagePath, createdAt])
}

model AlertRule {
  id            String       @id @default(cuid())
  workspaceId   String
  createdById   String
  name          String
  metric        String
  type          AlertType
  comparator    String
  threshold     Float?
  channels      AlertChannel[]
  slackWebhook  String?
  emailTargets  String[]
  enabled       Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy     User         @relation("AlertRuleCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  events        AlertEvent[]

  @@index([workspaceId, enabled, createdAt])
}

model AlertEvent {
  id               String           @id @default(cuid())
  workspaceId      String
  ruleId           String
  status           AlertEventStatus @default(OPEN)
  title            String
  message          String
  metricValue      Float?
  breachedAt       DateTime         @default(now())
  acknowledgedAt   DateTime?
  acknowledgedById String?
  metadata         Json?
  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  rule             AlertRule        @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  acknowledgedBy   User?            @relation("AlertEventAcknowledgedBy", fields: [acknowledgedById], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, breachedAt])
}

model ExportJob {
  id             String          @id @default(cuid())
  workspaceId    String
  createdById    String
  datasetId      String?
  format         ExportFormat
  status         ExportJobStatus @default(QUEUED)
  scheduleCron   String?
  artifactKey    String?
  errorMessage   String?
  payload        Json?
  auditMetadata  Json?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy      User            @relation("ExportJobCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  dataset        Dataset?        @relation(fields: [datasetId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, status, createdAt])
}

model Subscription {
  id                String             @id @default(cuid())
  workspaceId       String
  provider          String             @default("stripe")
  externalId        String?
  plan              WorkspacePlan
  status            SubscriptionStatus @default(TRIALING)
  trialEndsAt       DateTime?
  currentPeriodEnd  DateTime?
  overageRows       Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, createdAt])
}

model BillingEvent {
  id           String    @id @default(cuid())
  workspaceId  String
  provider     String    @default("stripe")
  eventType    String
  providerEventId String?
  payload      Json
  createdAt    DateTime  @default(now())
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([provider, providerEventId])
  @@index([workspaceId, createdAt])
}

model UsageMeter {
  id             String    @id @default(cuid())
  workspaceId    String
  metric         String
  quantity       Int       @default(0)
  windowStart    DateTime
  windowEnd      DateTime
  createdAt      DateTime  @default(now())
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, metric, windowStart])
}

model GdprRequest {
  id             String            @id @default(cuid())
  workspaceId    String
  requestedById  String
  requestType    GdprRequestType
  subjectEmail   String
  status         GdprRequestStatus @default(REQUESTED)
  artifactKey    String?
  rejectionReason String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  completedAt    DateTime?
  workspace      Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requestedBy    User              @relation(fields: [requestedById], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, createdAt])
}

model DpaAgreement {
  id             String    @id @default(cuid())
  workspaceId    String
  acceptedById   String
  version        String
  acceptedAt     DateTime  @default(now())
  metadata       Json?
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  acceptedBy     User      @relation(fields: [acceptedById], references: [id], onDelete: Cascade)
}

model RetentionPolicy {
  id             String    @id @default(cuid())
  workspaceId    String
  resourceType   String
  retentionDays  Int
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, resourceType])
}

model Subprocessor {
  id             String    @id @default(cuid())
  workspaceId    String
  name           String
  purpose        String
  region         String?
  website        String?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, active, createdAt])
}

model SsoConfig {
  id             String          @id @default(cuid())
  workspaceId    String
  providerType   SSOProviderType
  issuer         String?
  entryPoint     String?
  clientId       String?
  clientSecret   String?
  metadataUrl    String?
  enabled        Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, providerType, enabled])
}

model BackupDrill {
  id             String      @id @default(cuid())
  workspaceId    String
  triggeredById  String
  status         DrillStatus
  notes          String?
  startedAt      DateTime    @default(now())
  completedAt    DateTime?
  workspace      Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  triggeredBy    User        @relation(fields: [triggeredById], references: [id], onDelete: Cascade)
}

model Runbook {
  id             String    @id @default(cuid())
  workspaceId    String
  name           String
  content        String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model SloTarget {
  id             String    @id @default(cuid())
  workspaceId    String
  name           String
  objective      Float
  measurement    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model IncidentPlaybook {
  id             String    @id @default(cuid())
  workspaceId    String
  ownerId        String
  title          String
  severity       String
  content        String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner          User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model DemoFixture {
  id             String    @id @default(cuid())
  workspaceId    String
  name           String
  description    String?
  datasetId      String?
  createdAt      DateTime  @default(now())
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
