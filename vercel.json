{
  "framework": "nextjs",
  "functions": {
    "app/api/analyze-dataset/route.ts": {
      "maxDuration": 60
    },
    "app/api/parse-file/route.ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=3600"
        }
      ]
    }
  ]
}
