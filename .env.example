# ─────────────────────────────────────────────────────────
# EcoDash Environment Variables
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local
# ─────────────────────────────────────────────────────────

# Required: Anthropic API key for AI-powered dataset analysis
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required for auth token verification in API routes
JWT_SECRET=replace-with-long-random-secret

# Required for Prisma/PostgreSQL backend persistence
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecodash
# Optional in local dev. If not set, ingestion runs inline fallback mode.
REDIS_URL=redis://localhost:6379

# Required for connector credential encryption (32-byte key encoded as base64 or hex)
CONNECTOR_ENCRYPTION_KEY=replace-with-32-byte-base64-or-hex-key

# Optional issuer label shown in authenticator apps for MFA TOTP setup
MFA_ISSUER_NAME=EcoDash

# OAuth scaffold settings
OAUTH_REDIRECT_BASE_URL=http://localhost:3000
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT_ID=common

# Optional Sentry DSN (backend/frontend instrumentation hooks)
SENTRY_DSN=

# Optional local-only bypass mode for integration testing.
# Keep false in normal dev/prod.
LOCAL_TEST_MODE=false
LOCAL_TEST_USER_ID=
LOCAL_TEST_WORKSPACE_ID=

# Optional scaffold gate: keep false in production until OAuth/connector sync are fully implemented.
ENABLE_SCAFFOLD_ENDPOINTS=false

# Optional upload scanning hook (recommended on production)
ENABLE_AV_SCAN=false
AV_SCAN_URL=

# Optional: Enable bundle analyzer (set to 'true' when running npm run build)
# ANALYZE=true

# Optional: only set true if you explicitly need inline script/style during rollout.
# Production default should remain strict (false/unset).
CSP_ALLOW_UNSAFE_INLINE=false
