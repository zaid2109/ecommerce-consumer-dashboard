# ─────────────────────────────────────────────────────────
# EcoDash Environment Variables
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local
# ─────────────────────────────────────────────────────────

# Required: Anthropic API key for AI-powered dataset analysis
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Enable bundle analyzer (set to 'true' when running npm run build)
# ANALYZE=true
